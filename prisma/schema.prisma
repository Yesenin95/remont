// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Модель пользователя
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  role         Role     @default(USER)
  passwordHash String?  // Хеш пароля
  posts        Post[]
  messages     Message[]
  assignedRepairs RepairRequest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

// Роль пользователя
enum Role {
  USER    // Обычный пользователь (клиент)
  MASTER  // Мастер - видит заявки, может общаться с клиентами
  OWNER   // Владелец - полный доступ + управление товарами/запчастями
}

// Модель поста/статьи
model Post {
  id          String   @id @default(uuid())
  title       String
  content     String?
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([published])
}

// Клиент (для авторизации)
model Customer {
  id          String   @id @default(uuid())
  email       String?  @unique
  phone       String?  @unique
  password    String
  name        String?
  repairs     RepairRequest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

// Услуга сервиса
model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int
  category    String
  available   Boolean  @default(true)
  repairs     RepairRequest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// Заявка на ремонт
model RepairRequest {
  id              String   @id @default(uuid())
  customerName    String
  phone           String
  deviceModel     String
  problem         String
  status          RepairStatus @default(PENDING)
  serviceId       String
  service         Service    @relation(fields: [serviceId], references: [id])
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  notes           String?
  assignedTo      String?    // ID мастера, закреплённого за заявкой
  assignedMaster  User?      @relation(fields: [assignedTo], references: [id])
  product         Product?   // Связанный товар (для trade-in)
  messages        Message[]
  
  // Поля для отслеживания клиентом
  requestNumber   String   @unique // Публичный номер заявки (например, R-12345)
  repairStage     RepairStage @default(DIAGNOSTICS) // Стадия ремонта для клиента
  media           String[] @default([]) // Массив URL фото/видео
  
  // Статус готовности к выдаче
  isReadyForPickup Boolean @default(false)
  pickupCode       String? // Код для получения (последние 4 цифры телефона)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([serviceId])
  @@index([assignedTo])
  @@index([requestNumber])
}

// Стадии ремонта для отслеживания клиентом
enum RepairStage {
  DIAGNOSTICS    // Диагностика
  REPAIR         // Ремонт
  READY          // Готов к выдаче
  ISSUED         // Выдан
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Категория товаров/запчастей
model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  products    Product[]
  parts       Part[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// Товар для продажи (готовые устройства)
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int
  cost        Int      // Себестоимость для расчёта прибыли
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  brand       String
  model       String?
  condition   ProductCondition
  status      ProductStatus @default(AVAILABLE)
  quantity    Int      @default(1)
  images      String[] // Массив URL изображений
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id])
  repairRequestId String? @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([brand])
}

enum ProductCondition {
  NEW         // Новый
  USED        // Б/у
  REFURBISHED // Восстановленный
  FOR_PARTS   // На запчасти
}

enum ProductStatus {
  AVAILABLE
  SOLD
  RESERVED
  IN_REPAIR
}

// Запчасть для ремонта
model Part {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int      // Цена продажи
  cost        Int      // Себестоимость
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  brand       String
  compatibleModels String? // Совместимые модели (через запятую)
  quantity    Int      @default(0)
  minQuantity Int      @default(5)  // Мин. остаток для уведомления
  supplier    String?  // Поставщик
  sku         String?  // Артикул
  status      PartStatus @default(IN_STOCK)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([brand])
}

enum PartStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  ON_ORDER
}

// Сообщение в заявке (чат между мастером и клиентом)
model Message {
  id          String   @id @default(uuid())
  content     String
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  repairRequestId String?
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id])
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([repairRequestId])
  @@index([senderId])
}
